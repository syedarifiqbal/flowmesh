# ─── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_PASSWORD=changeme_strong_password

# ─── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=changeme_generate_with_openssl_rand_hex_64

# ─── Service URLs (used internally between services) ──────────
# These default to Docker Compose service names — only override for custom deployments
# INGESTION_SERVICE_URL=http://ingestion:3001
# CONFIG_SERVICE_URL=http://config-service:3005
# AUTH_SERVICE_URL=http://auth:3004

# ─── Redis ────────────────────────────────────────────────────
# Redis 1 — ephemeral (rate limits, cache, pub/sub)
REDIS_EPHEMERAL_URL=redis://redis-ephemeral:6379

# Redis 2 — persistent (token blacklist, idempotency keys)
REDIS_PERSISTENT_URL=redis://redis-persistent:6379

# ─── Node Environment ─────────────────────────────────────────
NODE_ENV=production
